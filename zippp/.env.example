# Single DB for timetable + AI workflow collections
DATABASE_URL=mongodb+srv://<tt-user>:<tt-password>@<cluster-host>/department_timetable?retryWrites=true&w=majority
TIMETABLE_DB_NAME=department_timetable

# AI upstream FastAPI proxy target (can be CPU or GPU host)
AI_FASTAPI_BASE_URL=http://<ai-worker-host>:8000
AI_PROXY_TIMEOUT_SECONDS=300
AI_LOCAL_MODE=auto

# Legacy aliases still supported by api.py for backward compatibility:
# GPU_FASTAPI_BASE_URL=
# GPU_PROXY_TIMEOUT_SECONDS=

# Local execution intent flag (status visibility only)
AI_EXECUTION_DEVICE=cpu

# API runtime
PORT=8000
CORS_ALLOW_ORIGINS=*

# Shared secret with time-table-backend proxy — required and must match backend .env
GRADEAI_SHARED_SECRET=replace-with-a-long-random-secret
