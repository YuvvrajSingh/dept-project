{
  "info": {
    "_postman_id": "d2f2a0f1-7b37-4d07-95e4-9e2f1e59f8ab",
    "name": "Timetable API Happy Path",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Resolve CSE Branch From Seeded Data",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/classes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "classes"
          ]
        },
        "description": "Branches are seeded. This request resolves CSE branchId for the next steps."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const rows = pm.response.json();",
              "const cse = rows.find((r) => r.branch?.name === 'CSE');",
              "if (cse) {",
              "  pm.collectionVariables.set('branchId', String(cse.branchId));",
              "}",
              "pm.collectionVariables.set('year', '3');"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Create Teacher",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mrs. Simran Choudhary\",\n  \"abbreviation\": \"SCX\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/teachers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "teachers"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('teacherId', String(json.id));"
            ]
          }
        }
      ]
    },
