{
  "info": {
    "_postman_id": "84fd7b22-653c-4f44-a1d2-2c25e8b8584f",
    "name": "Timetable API Conflict Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Manual conflict testing suite for THEORY and LAB timetable entries. Run requests in order."
  },
  "item": [
    {
      "name": "0. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health is up', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1. Create Base THEORY Entry (Expected 201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"classSectionId\": {{classSectionIdBase}},\n  \"day\": {{dayTheory}},\n  \"slotStart\": {{slotTheory}},\n  \"entryType\": \"THEORY\",\n  \"subjectId\": {{subjectIdTheory}},\n  \"teacherId\": {{teacherIdBase}},\n  \"roomId\": {{roomIdBase}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/timetable/entry",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "timetable",
            "entry"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Created timetable entry', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('entryIdBase', String(json.id));"
            ]
          }
        }
      ]
    },
