      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Teacher 1 lab subject assigned or already exists', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
