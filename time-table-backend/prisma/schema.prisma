generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AcademicYearStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubjectType {
  THEORY
  LAB
}

// Renamed from EntryType; expanded to support future scheduling types.
enum TimetableEntryType {
  LECTURE
  LAB
}

// Typed notification categories — replaces the plain String column.
enum NotificationLogType {
  ENTRY_CREATED
  ENTRY_UPDATED
  ENTRY_DELETED
  ENTRY_CANCELLED
  ENTRY_CANCELLATION_UNDONE
}

enum Role {
  ADMIN
  TEACHER
}

// ─── Core Lookup Tables ───────────────────────────────────────────────────────

model AcademicYear {
  id            Int                @id @default(autoincrement())
  label         String             @unique
  startYear     Int
  endYear       Int
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  status        AcademicYearStatus @default(DRAFT)
  isActive      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  classSections ClassSection[]

  @@unique([startYear, endYear])
}

// Branch is a simple organizational label — no Department or HOD complexity.
model Branch {
  id       Int            @id @default(autoincrement())
  name     String         @unique
  sections ClassSection[]
}

// Replaces raw slotStart/slotEnd integers on TimetableEntry.
// These 6 rows must be seeded before any TimetableEntry can be created.
model Slot {
  id               Int              @id @default(autoincrement())
  label            String           @unique // "I", "II", "III", "IV", "V", "VI"
  order            Int              @unique // 1–6; used for stable sort and conflict resolution
  startTime        DateTime         @db.Time
  endTime          DateTime         @db.Time
  timetableEntries TimetableEntry[]
}

model Room {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  capacity         Int              @default(60)
  timetableEntries TimetableEntry[]
}

model Lab {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  capacity        Int             @default(20)
  labGroupEntries LabGroupEntry[]
}

// ─── Academic Entities ────────────────────────────────────────────────────────

model ClassSection {
  id             Int              @id @default(autoincrement())
  academicYearId Int
  branchId       Int
  year           Int
  semester       Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  branch         Branch           @relation(fields: [branchId], references: [id])
  subjects       ClassSubject[]
  timetable      TimetableEntry[]

  @@unique([academicYearId, branchId, year, semester])
}

model Subject {
  id               Int              @id @default(autoincrement())
  code             String           @unique
  name             String
  abbreviation     String           @default("")
  type             SubjectType
  creditHours      Int
  // Soft delete: set false to archive. Do not hard-delete active subjects —
  // LabGroupEntry and TimetableEntry use Restrict which will block the delete.
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  teacherSubjects  TeacherSubject[]
  classSubjects    ClassSubject[]
  timetableEntries TimetableEntry[]
  labGroupEntries  LabGroupEntry[]
}

model Teacher {
  id                 Int                 @id @default(autoincrement())
  name               String
  abbreviation       String              @unique
  email              String?
  // Soft delete: set false to archive. Hard delete is blocked by Restrict
  // on LabGroupEntry (historical lab data must not lose its teacher reference).
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User?
  teacherSubjects    TeacherSubject[]
  timetableEntries   TimetableEntry[]
  labGroupEntries    LabGroupEntry[]
  entryCancellations EntryCancellation[]
}

// Auth accounts: admins are not teachers; teachers link 1:1 via teacherId.
// CHECK constraints on role vs teacherId are enforced in SQL migration.
model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  passwordHash       String
  role               Role
  teacherId          Int?                @unique
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  teacher            Teacher?            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  entryCancellations EntryCancellation[]
}

// ─── Junction Tables ─────────────────────────────────────────────────────────

model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int
  subjectId Int
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model ClassSubject {
  id             Int          @id @default(autoincrement())
  classSectionId Int
  subjectId      Int
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classSectionId, subjectId])
}

// ─── Timetable Core ───────────────────────────────────────────────────────────

model TimetableEntry {
  id               Int                 @id @default(autoincrement())
  classSectionId   Int
  slotId           Int // FK to Slot — replaces raw slotStart/slotEnd integers
  day              Int // 1 = Monday … 6 = Saturday
  entryType        TimetableEntryType
  // subjectId is nullable (LAB entries set it null; lab group subjects live on LabGroupEntry).
  // Restrict means: if a subject IS attached, you cannot delete it — use isActive=false instead.
  subjectId        Int?
  teacherId        Int?
  roomId           Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  classSection     ClassSection        @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  slot             Slot                @relation(fields: [slotId], references: [id], onDelete: Restrict)
  subject          Subject?            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher          Teacher?            @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room             Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  labGroups        LabGroupEntry[]
  notificationLogs NotificationLog[]
  cancellations    EntryCancellation[]

  // A class section cannot have two entries in the same day+slot.
  @@unique([classSectionId, day, slotId])
  // Composite indexes for fast teacher and room conflict lookups (app-level checks).
  @@index([teacherId, day, slotId])
  @@index([roomId, day, slotId])
}

model LabGroupEntry {
  id               Int            @id @default(autoincrement())
  timetableEntryId Int
  groupName        String // "A1", "A2", "A3"
  subjectId        Int // Non-nullable: every lab group must have a subject
  labId            Int
  teacherId        Int
  timetableEntry   TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  // Restrict prevents deleting subjects/labs/teachers referenced in historical lab data.
  // Use isActive=false on Teacher/Subject for soft archival instead.
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  lab              Lab            @relation(fields: [labId], references: [id], onDelete: Restrict)
  teacher          Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
}

model EntryCancellation {
  id                   Int      @id @default(autoincrement())
  timetableEntryId     Int
  cancelDate           String // Format: YYYY-MM-DD
  reason               String?
  cancelledByTeacherId Int?
  cancelledByAdminId   Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  timetableEntry     TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  cancelledByTeacher Teacher?       @relation(fields: [cancelledByTeacherId], references: [id], onDelete: SetNull)
  cancelledByAdmin   User?          @relation(fields: [cancelledByAdminId], references: [id], onDelete: SetNull)

  @@unique([timetableEntryId, cancelDate])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationLog {
  id               Int                 @id @default(autoincrement())
  timetableEntryId Int? // Nullable to survive entry deletion
  performedBy      String? // "Admin", teacher name, etc.
  type             NotificationLogType
  message          String // Human-readable description
  metadata         Json? // Structured data (subject, teacher, etc.)
  date             DateTime            @db.Date
  createdAt        DateTime            @default(now())
  timetableEntry   TimetableEntry?     @relation(fields: [timetableEntryId], references: [id], onDelete: SetNull)
}
