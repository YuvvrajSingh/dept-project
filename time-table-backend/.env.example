DATABASE_URL="mongodb+srv://<user>:<password>@<cluster-host>/department_timetable?retryWrites=true&w=majority"

# API (default 3001 so Next.js can use 3000)
PORT=3001

# Auth — single JWT in http-only cookie (no refresh token in v1). Set the same JWT_SECRET in the Next app for middleware.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# GradeAI upstream service URL (python service)
GRADEAI_API_URL=http://127.0.0.1:8000

# Shared secret between Node proxy and zippp — required and must match zippp/.env
GRADEAI_SHARED_SECRET=replace-with-a-long-random-secret

# Seed-only: first admin user (npm run db:seed)
ADMIN_EMAIL=admin@dept.local
ADMIN_PASSWORD=changeme

# Optional: comma-separated browser origins (defaults include localhost:3000 and :5173)
# CORS_ORIGIN=http://localhost:3000
